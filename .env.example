ADMANAGEMENT_APP_NAME=admanagement
ADMANAGEMENT_ENVIRONMENT=dev
ADMANAGEMENT_DEBUG=true
ADMANAGEMENT_HOST=0.0.0.0
ADMANAGEMENT_PORT=8000
ADMANAGEMENT_DATABASE_URL=postgresql+psycopg://admanagement:admanagement@localhost:5432/admanagement
ADMANAGEMENT_REDIS_URL=redis://localhost:6379/0
ADMANAGEMENT_LDAP_SERVER=ldaps://somedomaincontroller
ADMANAGEMENT_LDAP_BIND_DN=CN=svc-admanagement,OU=Service Accounts,DC=watuug,DC=watuafrica,DC=co,DC=ug
ADMANAGEMENT_LDAP_BIND_PASSWORD=change-me
ADMANAGEMENT_LDAP_BASE_DN=DC=some,DC=domain
ADMANAGEMENT_LDAP_PAGE_SIZE=500
ADMANAGEMENT_LDAP_CONNECT_TIMEOUT=15
ADMANAGEMENT_LDAP_PRIVILEGED_GROUPS=["Domain Admins","Enterprise Admins","Administrators","DnsAdmins","Group Policy Creator Owners"]
ADMANAGEMENT_EVENT_INGESTOR_MODE=winrm
ADMANAGEMENT_EVENT_DC_LIST=[""]
ADMANAGEMENT_EVENT_WINDOW_MINUTES=5
ADMANAGEMENT_EVENT_OVERLAP_SECONDS=60
ADMANAGEMENT_EVENT_MAX_RECORDS_PER_POLL=1000
ADMANAGEMENT_EVENT_SKIP_ORIGIN_CORRELATION=false
ADMANAGEMENT_WINRM_USERNAME=svc-admanagement
ADMANAGEMENT_WINRM_DOMAIN=SOMEDOMAIN
ADMANAGEMENT_WINRM_PASSWORD=change-me
ADMANAGEMENT_WINRM_AUTH=ntlm
ADMANAGEMENT_WINRM_USE_SSL=true
ADMANAGEMENT_WINRM_PORT=5986
ADMANAGEMENT_WINRM_SERVER_CERT_VALIDATION=ignore
ADMANAGEMENT_WINRM_OPERATION_TIMEOUT=60
ADMANAGEMENT_WINRM_READ_TIMEOUT=180
ADMANAGEMENT_REPORT_OUTPUT_DIR=admanagement-data/reports
ADMANAGEMENT_SCHEDULER_ENABLED=true
ADMANAGEMENT_LDAP_SNAPSHOT_INTERVAL_MINUTES=60
ADMANAGEMENT_ACTIVITY_POLL_INTERVAL_MINUTES=5
ADMANAGEMENT_LOGON_POLL_INTERVAL_MINUTES=5
ADMANAGEMENT_DASHBOARD_RECENT_ACTIVITY_LIMIT=20
ADMANAGEMENT_FRONTEND_ORIGINS=["http://127.0.0.1:3000","http://localhost:3000","http://192.168.10.4:3000"]
ADMANAGEMENT_UPDATE_CHECK_ENABLED=true
ADMANAGEMENT_UPDATE_CHECK_INTERVAL_MINUTES=360
ADMANAGEMENT_UPDATE_REPOSITORY=hackzaid/admanagement
ADMANAGEMENT_UPDATE_CHANNEL=branch
ADMANAGEMENT_UPDATE_BRANCH=main
ADMANAGEMENT_UPDATE_GITHUB_TOKEN=
ADMANAGEMENT_UPDATE_DEPLOY_MODE=docker-compose
ADMANAGEMENT_BUILD_COMMIT=

POSTGRES_DB=admanagement
POSTGRES_USER=admanagement
POSTGRES_PASSWORD=admanagement
# Host ports exposed by docker-compose.prod.yml.
# If 8000 or 3000 are already in use, set alternatives before starting
# or use ./scripts/install-ubuntu.sh which will pick free ports automatically.
BACKEND_PORT=8000
FRONTEND_PORT=3000
# The browser will automatically replace localhost/127.0.0.1/0.0.0.0
# with the current server hostname or IP while keeping this backend port.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
INTERNAL_API_BASE_URL=http://backend:8000
